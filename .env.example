# =============================================================================
# TBS Digital — root environment template.
# Copy to `.env` (never commit the real .env) and fill in the values:
#     cp .env.example .env
# `docker compose` / `make up` read this file automatically.
#
# -----------------------------------------------------------------------------
# PRODUCTION CHECKLIST (do all of these before going live):
#   [ ] Set ENVIRONMENT=production (turns on the fail-fast guard below).
#   [ ] Change EVERY secret below (POSTGRES_PASSWORD, ADMIN_PASSWORD, JWT_SECRET).
#   [ ] Generate a strong JWT_SECRET:   openssl rand -hex 32
#   [ ] Set your real domain in CORS_ORIGINS and NEXT_PUBLIC_API_URL
#       (NEXT_PUBLIC_API_URL is baked into the browser bundle at build time —
#        it must be the PUBLIC, host-facing API URL, e.g. https://api.your-domain).
#   [ ] Use managed Postgres OR the bundled `db` service; keep DATABASE_URL in sync.
#   [ ] Run behind HTTPS / a reverse proxy (Caddy, Nginx, Traefik) and stop
#       publishing the Postgres port (5432) to the public internet.
#   [ ] (Telegram) pin TELEGRAM_GROUP_CHAT_ID and set TELEGRAM_ADMIN_IDS.
# =============================================================================

# -----------------------------------------------------------------------------
# Deployment environment
#   "development" (default) or "production". In production the backend REFUSES
#   to boot with insecure defaults: a default/short JWT_SECRET, the default
#   ADMIN_PASSWORD, or a "*" in CORS_ORIGINS. Set this to production when hosting.
#   (docker-compose.prod.yml also forces ENVIRONMENT=production.)
# -----------------------------------------------------------------------------
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Postgres (the `db` service)
# -----------------------------------------------------------------------------
POSTGRES_USER=tbs
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=tbs_digital

# -----------------------------------------------------------------------------
# Backend database connection
#   Must match the Postgres values above. Host is the compose service name `db`
#   (reachable inside the network on port 5432). For managed Postgres, replace
#   the whole URL with your provider's connection string.
#   The backend also accepts SQLite (e.g. sqlite:///./data/app.db) as a fallback.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://tbs:change-me-strong-db-password@db:5432/tbs_digital

# -----------------------------------------------------------------------------
# Backend app
# -----------------------------------------------------------------------------
APP_NAME=TBS Digital API

# Where the JSON stand-in / SQLite fallback writes its files (inside the container).
DATA_DIR=/app/data

# Admin login. The backend seeds a hashed admin user from these on startup.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-admin-password

# JWT signing. Use >= 32 random bytes:  openssl rand -hex 32
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
# Token lifetime in minutes (720 = 12h).
JWT_EXPIRE_MINUTES=720

# Comma-separated origins allowed by CORS. Include every frontend origin.
# Dev: http://localhost:3000   Prod: https://your-domain
CORS_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Frontend (Next.js)
#   BAKED INTO THE CLIENT BUNDLE AT BUILD TIME. The browser reaches the backend
#   through this URL, so it must be the HOST-FACING address — NOT the internal
#   http://backend:8000. Rebuild the frontend image after changing it.
#   Dev: http://localhost:8000   Prod: https://api.your-domain
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Telegram lead-notification bot
#   Sends new contact-form leads to a Telegram group (one forum Topic per lead).
#   - TELEGRAM_BOT_TOKEN: get it from @BotFather (talk to it, /newbot, copy the
#       "HTTP API" token). Keep it secret — put the real value only in `.env`.
#   - The bot MUST be added to the target group AS AN ADMIN with the
#       "Manage Topics" permission, and the group must have Topics enabled.
#   - TELEGRAM_GROUP_CHAT_ID: can stay EMPTY — send `/register` in the group and
#       the bot captures & stores the chat id itself.
#   - TELEGRAM_ENABLED: set to false to disable all Telegram calls.
#   - TELEGRAM_ADMIN_IDS: comma-separated Telegram user ids allowed to run
#       /register, /stats and the lead classification buttons. Recommended in
#       production (get your id from @userinfobot). Empty => those actions are
#       allowed only from the already-registered group.
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
# Leave empty; captured automatically via /register in the group.
TELEGRAM_GROUP_CHAT_ID=
TELEGRAM_ENABLED=true
TELEGRAM_ADMIN_IDS=
