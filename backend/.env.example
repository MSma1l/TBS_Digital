# Copy to .env and adjust. Never commit the real .env.
APP_NAME=TBS Digital API

# Comma-separated origins allowed by CORS (the Next.js app).
CORS_ORIGINS=http://localhost:3000

# Database connection string.
# Default is a local SQLite file (its parent dir is created automatically).
DATABASE_URL=sqlite:///./data/tbs.db
# Postgres example (uncomment to use; needs psycopg[binary] from requirements):
# DATABASE_URL=postgresql://tbs:tbs@localhost:5432/tbs

# Legacy: used only by the JSONFileStore reference/fallback store.
DATA_DIR=data

# --- Admin bootstrap. On first run these SEED the DB `users` table (password hashed). ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
JWT_SECRET=please-change-this-to-a-long-random-string
JWT_EXPIRE_MINUTES=720

# --- Telegram lead-notification bot ---
#   Sends new contact-form leads to a Telegram group (one forum Topic per lead).
#   - TELEGRAM_BOT_TOKEN: get it from @BotFather (/newbot, copy the HTTP API
#       token). Keep it secret — real value goes only in `.env`, never here.
#   - The bot MUST be added to the group AS AN ADMIN with the "Manage Topics"
#       permission, and the group must have Topics enabled.
#   - TELEGRAM_GROUP_CHAT_ID: can stay EMPTY — send `/register` in the group and
#       the bot captures & stores the chat id itself.
#   - TELEGRAM_ENABLED: set to false to disable all Telegram calls.
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
# Leave empty; captured automatically via /register in the group.
TELEGRAM_GROUP_CHAT_ID=
TELEGRAM_ENABLED=true
