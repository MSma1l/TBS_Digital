# Copy to .env and adjust. Never commit the real .env.
APP_NAME=TBS Digital API

# Comma-separated origins allowed by CORS (the Next.js app).
CORS_ORIGINS=http://localhost:3000

# Where the JSON stand-in stores content.json / submissions.json.
DATA_DIR=data

# --- Admin auth stand-in (env credentials -> JWT). Replace with DB users later. ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
JWT_SECRET=please-change-this-to-a-long-random-string
JWT_EXPIRE_MINUTES=720
