# Frontend-only env for LOCAL dev without Docker (`npm run dev` / `make dev-frontend`).
# Next.js auto-loads `.env.local`. Copy this file:  cp .env.local.example .env.local
#
# Point the browser at wherever your backend runs locally. This is a public,
# client-side value (NEXT_PUBLIC_*), so use the host-facing URL.
NEXT_PUBLIC_API_URL=http://localhost:8000
